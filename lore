<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Blood of My Blood</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --crimson: #8b0000;
      --crimson-light: #c0392b;
      --gold: #c9a84c;
      --gold-light: #e8d5a3;
      --cream: #f5efe6;
      --dark: #0a0608;
      --dark2: #110d0f;
      --dark3: #1a1215;
      --text: #d4c5b0;
      --text-dim: #8a7a6a;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--dark);
      color: var(--text);
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      line-height: 1.8;
      overflow-x: hidden;
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--dark); }
    ::-webkit-scrollbar-thumb { background: var(--crimson); border-radius: 3px; }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 20px 48px;
      background: linear-gradient(to bottom, rgba(10,6,8,0.95), transparent);
    }
    .nav-logo {
      font-family: 'Cinzel', serif;
      font-size: 11px; letter-spacing: 0.25em;
      color: var(--crimson-light); text-decoration: none;
      text-transform: uppercase;
    }
    .nav-links { display: flex; gap: 40px; list-style: none; }
    .nav-links a {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.3em;
      color: var(--text-dim); text-decoration: none;
      text-transform: uppercase;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--gold); }

    /* ─── HERO ─── */
    #hero {
      position: relative; height: 100vh;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 65% 45%, rgba(80,20,20,0.35) 0%, transparent 60%),
        radial-gradient(ellipse at 50% 50%, rgba(139,0,0,0.15) 0%, transparent 70%),
        linear-gradient(to bottom, #0a0608 0%, #1a0d10 40%, #0d0608 100%);
    }
    /* moon */
    .hero-bg::before {
      content: '';
      position: absolute; top: 12%; right: 22%;
      width: 280px; height: 280px; border-radius: 50%;
      background: radial-gradient(circle, rgba(200,160,120,0.18) 0%, rgba(150,100,80,0.08) 50%, transparent 70%);
      box-shadow: 0 0 80px 40px rgba(180,120,80,0.1);
    }
    .hero-content { position: relative; z-index: 2; }
    .hero-eyebrow {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.4em;
      color: var(--gold); text-transform: uppercase;
      margin-bottom: 24px; opacity: 0.8;
    }
    .hero-title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(52px, 9vw, 110px);
      font-weight: 700; line-height: 0.95;
      color: var(--cream);
      text-shadow: 0 0 60px rgba(139,0,0,0.5), 0 2px 4px rgba(0,0,0,0.8);
      letter-spacing: 0.02em;
      margin-bottom: 28px;
    }
    .hero-sub {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 20px;
      color: var(--gold); letter-spacing: 0.05em;
    }
    .scroll-hint {
      position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
      font-family: 'Cinzel', serif; font-size: 9px;
      letter-spacing: 0.35em; color: var(--text-dim);
      text-transform: uppercase; z-index: 2;
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:0.4} 50%{opacity:0.9} }

    /* ─── DIVIDER ─── */
    .ornament {
      text-align: center; color: var(--crimson);
      font-size: 14px; letter-spacing: 0.5em;
      margin: 12px 0; opacity: 0.7;
    }

    /* ─── SECTION BASE ─── */
    section { padding: 100px 0; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 48px; }
    .container-wide { max-width: 1300px; margin: 0 auto; padding: 0 48px; }

    .section-label {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.4em;
      color: var(--crimson-light); text-transform: uppercase;
      margin-bottom: 8px;
    }
    .section-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 11px; letter-spacing: 0.3em;
      color: var(--text-dim); text-transform: uppercase;
      margin-bottom: 6px;
    }
    .section-title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(28px, 4vw, 48px);
      color: var(--cream); line-height: 1.1;
      margin-bottom: 8px;
    }
    .section-subtitle {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 16px;
      color: var(--text-dim); letter-spacing: 0.05em;
    }
    .section-header { margin-bottom: 60px; }

    /* ─── ZALOTHOS INTRO ─── */
    #zalothos { background: var(--dark2); }

    .zalothos-welcome {
      text-align: center;
      margin-bottom: 64px;
    }
    .zalothos-welcome .welcome-small {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px; letter-spacing: 0.2em;
      color: var(--text-dim); margin-bottom: 12px;
    }
    .zalothos-welcome .welcome-title {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(48px, 8vw, 96px);
      color: var(--cream);
      text-shadow: 0 0 40px rgba(139,0,0,0.4);
      line-height: 1; margin-bottom: 16px;
    }
    .zalothos-welcome .welcome-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(20px, 2.5vw, 28px);
      color: var(--gold-light); letter-spacing: 0.08em;
      font-weight: 300;
    }

    /* city gallery 4 images */
    .city-gallery {
      display: grid;
      grid-template-columns: 1fr 1.4fr 1fr;
      grid-template-rows: auto auto;
      gap: 12px;
      margin-bottom: 32px;
    }
    .city-gallery .img-wrap {
      overflow: hidden;
      position: relative;
    }
    .city-gallery .img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      transition: transform 0.6s ease;
    }
    .city-gallery .img-wrap:hover img { transform: scale(1.04); }

    /* layout: [img1 tall left] [img2 center top] [img3 tall right] / [empty] [img4 center bottom] [empty] */
    .city-gallery .g1 { grid-column: 1; grid-row: 1 / 3; aspect-ratio: 9/16; }
    .city-gallery .g2 { grid-column: 2; grid-row: 1; aspect-ratio: 9/10; }
    .city-gallery .g3 { grid-column: 3; grid-row: 1 / 3; aspect-ratio: 9/16; }
    .city-gallery .g4 { grid-column: 2; grid-row: 2; aspect-ratio: 9/10; }

    /* img2 crop to hide watermark — zoom & shift up */
    .city-gallery .g2 img { object-position: center 20%; transform: scale(1.15); }
    .city-gallery .g2:hover img { transform: scale(1.19); }

    .gallery-caption {
      text-align: center;
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 17px;
      color: var(--text-dim); letter-spacing: 0.04em;
      margin-bottom: 72px; padding: 0 60px;
      line-height: 1.7;
    }

    /* city info blocks */
    .city-info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px 64px;
      margin-bottom: 72px;
    }
    .city-info-block {}
    .city-info-block .info-icon {
      font-family: 'Cinzel', serif;
      font-size: 9px; letter-spacing: 0.4em;
      color: var(--crimson-light); text-transform: uppercase;
      margin-bottom: 10px;
    }
    .city-info-block h3 {
      font-family: 'Cinzel', serif;
      font-size: 15px; letter-spacing: 0.15em;
      color: var(--cream); margin-bottom: 14px;
      text-transform: uppercase;
    }
    .city-info-block p {
      font-size: 17px; color: var(--text);
      line-height: 1.9;
    }
    .city-info-imgs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px; margin-top: 16px;
    }
    .city-info-imgs img {
      width: 100%; aspect-ratio: 4/3;
      object-fit: cover; display: block;
    }

    /* extra city photos */
    .city-extra-imgs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px; margin-bottom: 72px;
    }
    .city-extra-imgs img {
      width: 100%; aspect-ratio: 16/9;
      object-fit: cover; display: block;
    }

    /* vampire ruler banner */
    .vampire-ruler-banner {
      position: relative;
      width: 100%; margin-bottom: 64px;
      overflow: hidden;
    }
    .vampire-ruler-banner img {
      width: 100%; max-height: 420px;
      object-fit: cover; object-position: center 30%;
      display: block;
      filter: brightness(0.75) saturate(0.8);
    }
    .vampire-ruler-banner::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 30%, var(--dark2) 100%);
    }
    .vampire-ruler-text {
      position: absolute; bottom: 0; left: 0; right: 0;
      z-index: 2; text-align: center; padding: 32px 48px;
    }
    .vampire-ruler-text h2 {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(24px, 4vw, 48px);
      color: var(--cream);
      text-shadow: 0 0 30px rgba(139,0,0,0.6);
    }

    /* vampire lore */
    .vampire-lore { margin-bottom: 64px; }
    .vampire-lore p {
      font-size: 18px; line-height: 2;
      color: var(--text); margin-bottom: 20px;
      text-align: center; max-width: 800px; margin-left: auto; margin-right: auto;
    }

    /* founder image */
    .founder-img-wrap {
      text-align: center; margin: 40px 0;
    }
    .founder-img-wrap img {
      max-width: 480px; width: 100%;
      display: inline-block;
      border: 1px solid rgba(139,0,0,0.3);
      box-shadow: 0 0 40px rgba(139,0,0,0.2);
    }

    /* bloodlines */
    .bloodlines-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px; margin-top: 48px;
    }
    .bloodline-card {
      text-align: center;
      border: 1px solid rgba(139,0,0,0.2);
      padding: 32px 24px;
      background: rgba(139,0,0,0.04);
      transition: border-color 0.3s, background 0.3s;
    }
    .bloodline-card:hover {
      border-color: rgba(139,0,0,0.5);
      background: rgba(139,0,0,0.08);
    }
    .bloodline-card img {
      width: 100%; aspect-ratio: 3/4;
      object-fit: cover; object-position: center top;
      display: block; margin-bottom: 20px;
      filter: saturate(0.7) brightness(0.85);
      transition: filter 0.4s;
    }
    .bloodline-card:hover img { filter: saturate(0.9) brightness(0.95); }
    .bloodline-card .bl-name {
      font-family: 'Cinzel Decorative', serif;
      font-size: 18px; color: var(--cream);
      margin-bottom: 6px;
    }
    .bloodline-card .bl-role {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.3em;
      color: var(--crimson-light); text-transform: uppercase;
      margin-bottom: 12px;
    }
    .bloodline-card .bl-desc {
      font-size: 15px; color: var(--text-dim);
      line-height: 1.7;
    }

    /* ─── SOCIETY ─── */
    #society { background: var(--dark3); }

    .intro-text {
      font-size: 19px; line-height: 2;
      color: var(--text); margin-bottom: 48px;
      max-width: 820px;
    }
    .intro-text strong { color: var(--cream); font-weight: 600; }
    .intro-text em { color: var(--gold); font-style: italic; }

    .three-clans {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px; margin: 60px 0;
    }
    .clan-card {
      padding: 48px 32px;
      background: rgba(255,255,255,0.02);
      border-top: 1px solid rgba(139,0,0,0.3);
      transition: background 0.3s;
    }
    .clan-card:hover { background: rgba(139,0,0,0.06); }
    .clan-img {
      width: 80px; height: 80px; border-radius: 50%;
      object-fit: cover; margin-bottom: 20px;
      border: 1px solid rgba(139,0,0,0.4);
      filter: grayscale(0.3);
    }
    .clan-name {
      font-family: 'Cinzel Decorative', serif;
      font-size: 16px; color: var(--cream);
      margin-bottom: 6px;
    }
    .clan-role {
      font-family: 'Cinzel', serif;
      font-size: 9px; letter-spacing: 0.35em;
      color: var(--gold); text-transform: uppercase;
      margin-bottom: 16px;
    }
    .clan-desc { font-size: 16px; color: var(--text-dim); line-height: 1.8; }

    .society-note {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 18px;
      color: var(--text-dim); text-align: center;
      padding: 40px; border-top: 1px solid rgba(139,0,0,0.15);
      border-bottom: 1px solid rgba(139,0,0,0.15);
      line-height: 1.9;
    }

    /* ─── BLOOD RANK ─── */
    #blood-rank { background: var(--dark2); }

    .rank-table-wrap { overflow-x: auto; margin: 40px 0; }
    table {
      width: 100%; border-collapse: collapse;
      font-size: 16px;
    }
    thead tr {
      border-bottom: 1px solid rgba(139,0,0,0.4);
    }
    th {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.3em;
      color: var(--gold); text-transform: uppercase;
      padding: 16px 20px; text-align: left;
      font-weight: 400;
    }
    td {
      padding: 16px 20px; color: var(--text);
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: top;
    }
    tr:hover td { background: rgba(139,0,0,0.04); }
    .rank-badge {
      font-family: 'Cinzel', serif;
      font-size: 13px; color: var(--crimson-light);
      font-weight: 600;
    }

    .ghoul-section { margin-top: 72px; }
    .ghoul-section h3 {
      font-family: 'Cinzel', serif;
      font-size: 14px; letter-spacing: 0.2em;
      color: var(--cream); text-transform: uppercase;
      margin-bottom: 20px;
    }
    .ghoul-imgs {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 10px; margin: 24px 0;
    }
    .ghoul-imgs img {
      width: 100%; aspect-ratio: 3/4;
      object-fit: cover; filter: saturate(0.3) brightness(0.7);
    }

    /* ─── VAMPIRE LIFE ─── */
    #vampire-life { background: var(--dark3); }

    .life-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px 64px; margin-bottom: 72px;
    }
    .life-block p { font-size: 17px; line-height: 2; color: var(--text); }
    .life-block h3 {
      font-family: 'Cinzel', serif;
      font-size: 12px; letter-spacing: 0.25em;
      color: var(--gold); text-transform: uppercase;
      margin-bottom: 14px;
    }

    .blood-rite-box {
      border: 1px solid rgba(139,0,0,0.3);
      padding: 48px; margin: 48px 0;
      background: rgba(139,0,0,0.04);
    }
    .blood-rite-box h3 {
      font-family: 'Cinzel Decorative', serif;
      font-size: 22px; color: var(--cream);
      margin-bottom: 20px;
    }
    .blood-rite-box p { font-size: 17px; line-height: 2; color: var(--text); }

    .life-imgs {
      display: grid; grid-template-columns: repeat(4,1fr);
      gap: 8px; margin: 32px 0;
    }
    .life-imgs img {
      width: 100%; aspect-ratio: 3/4;
      object-fit: cover; filter: saturate(0.6);
    }

    /* ─── CHARACTER ─── */
    #character { background: var(--dark2); }

    .char-intro {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 20px;
      color: var(--text-dim); text-align: center;
      margin-bottom: 64px; line-height: 1.9;
    }
    .char-intro strong { color: var(--gold); font-style: normal; }

    .char-layout {
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 64px; align-items: start;
    }
    .char-portrait img {
      width: 100%; display: block;
      border: 1px solid rgba(139,0,0,0.3);
      box-shadow: 0 0 60px rgba(139,0,0,0.15);
    }
    .char-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 0; margin-top: 20px;
      border: 1px solid rgba(139,0,0,0.2);
    }
    .stat-item {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(139,0,0,0.1);
    }
    .stat-item:nth-child(odd) { border-right: 1px solid rgba(139,0,0,0.1); }
    .stat-label {
      font-family: 'Cinzel', serif;
      font-size: 9px; letter-spacing: 0.3em;
      color: var(--text-dim); text-transform: uppercase;
      margin-bottom: 4px;
    }
    .stat-val { font-size: 15px; color: var(--cream); }

    .char-name {
      font-family: 'Cinzel Decorative', serif;
      font-size: clamp(28px, 4vw, 44px);
      color: var(--cream); margin-bottom: 8px;
    }
    .char-tagline {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 17px;
      color: var(--text-dim); margin-bottom: 32px;
    }
    .char-body p {
      font-size: 17px; line-height: 2;
      color: var(--text); margin-bottom: 20px;
    }
    .char-body strong { color: var(--cream); }

    .char-quote {
      border-left: 2px solid var(--crimson);
      padding: 20px 28px; margin: 32px 0;
      background: rgba(139,0,0,0.04);
    }
    .char-quote p {
      font-family: 'IM Fell English', serif;
      font-style: italic; font-size: 18px;
      color: var(--gold-light); margin-bottom: 8px !important;
    }
    .char-quote cite {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.3em;
      color: var(--text-dim); text-transform: uppercase;
    }

    .traits-list {
      display: flex; flex-wrap: wrap; gap: 8px;
      margin: 20px 0;
    }
    .trait-tag {
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.2em;
      color: var(--text-dim); text-transform: uppercase;
      border: 1px solid rgba(139,0,0,0.3);
      padding: 6px 14px;
    }

    .family-grid {
      display: grid; grid-template-columns: repeat(2,1fr);
      gap: 20px; margin-top: 32px;
    }
    .family-card {
      padding: 20px 24px;
      border: 1px solid rgba(139,0,0,0.15);
      background: rgba(255,255,255,0.01);
    }
    .family-card .f-name {
      font-family: 'Cinzel', serif;
      font-size: 13px; color: var(--cream);
      margin-bottom: 4px;
    }
    .family-card .f-role {
      font-family: 'Cinzel', serif;
      font-size: 9px; letter-spacing: 0.3em;
      color: var(--crimson-light); text-transform: uppercase;
      margin-bottom: 10px;
    }
    .family-card p { font-size: 15px; color: var(--text-dim); line-height: 1.7; }

    /* ─── FOOTER ─── */
    footer {
      background: var(--dark);
      border-top: 1px solid rgba(139,0,0,0.2);
      padding: 40px 48px;
      text-align: center;
      font-family: 'Cinzel', serif;
      font-size: 10px; letter-spacing: 0.3em;
      color: var(--text-dim); text-transform: uppercase;
      line-height: 2;
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .city-gallery { grid-template-columns: 1fr 1fr; }
      .city-gallery .g1 { grid-column: 1; grid-row: 1; aspect-ratio: 9/16; }
      .city-gallery .g2 { grid-column: 2; grid-row: 1; }
      .city-gallery .g3 { grid-column: 1; grid-row: 2; aspect-ratio: 9/16; }
      .city-gallery .g4 { grid-column: 2; grid-row: 2; }
      .city-info-grid { grid-template-columns: 1fr; }
      .three-clans { grid-template-columns: 1fr; }
      .bloodlines-grid { grid-template-columns: 1fr; }
      .char-layout { grid-template-columns: 1fr; }
      .char-portrait { max-width: 320px; }
      .life-grid { grid-template-columns: 1fr; }
      nav { padding: 16px 24px; }
      .nav-links { gap: 20px; }
      .container, .container-wide { padding: 0 24px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo">Blood of My Blood</a>
  <ul class="nav-links">
    <li><a href="#zalothos">Zalothos</a></li>
    <li><a href="#society">Society</a></li>
    <li><a href="#blood-rank">Blood Rank</a></li>
    <li><a href="#vampire-life">Vampire Life</a></li>
    <li><a href="#character">Character</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
